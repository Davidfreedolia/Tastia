# =============================================================================
# Tastia — variables de entorno
# =============================================================================
# Copia este archivo a .env y rellena con los valores reales.
# .env está en .gitignore: NUNCA se commitea.

# --- Cliente (Vite) ------------------------------------------------------------
# Se envían al navegador. NO uses aquí service_role ni claves secretas.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Servidor: Supabase --------------------------------------------------------
# Mismo URL que VITE_SUPABASE_URL (lo usan rutas server-side / edge functions).
SUPABASE_URL=
# service_role: bypasea RLS. SOLO server-side. Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=
# Alias usado por algunas funciones; mismo valor que SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_SERVICE_KEY=

# --- Servidor: Stripe (checkout + webhook + recibo) ----------------------------
# Stripe dashboard → Developers → API keys (test mode).
STRIPE_SECRET_KEY=
# Stripe dashboard → Webhooks → endpoint → Signing secret.
STRIPE_WEBHOOK_SECRET=

# --- Servidor: Resend (emails de recibo) --------------------------------------
# Resend dashboard → API keys. El código lee primero RESEND_TASTIA_API_KEY
# y cae a RESEND_API_KEY si la primera no está definida.
RESEND_TASTIA_API_KEY=
# Remitente: en pruebas `onboarding@resend.dev` solo entrega al email verificado
# de la cuenta Resend. Para entregar a cualquier destinatario, usa un dominio
# verificado.
RESEND_FROM=

# --- Scripts opcionales -------------------------------------------------------
# Solo lo usa scripts/import-wines.mjs. Déjalo vacío si no vas a correr el import.
DATABASE_URL=
