# Supabase — el frontend lee estos valores (VITE_ = públicos, se envían al navegador).
# Copia este archivo a .env y rellena con los valores de tu proyecto Supabase.
# La publishable key es la "anon/publishable" key, NO la service_role (esa nunca va al cliente).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
